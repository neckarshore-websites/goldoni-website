# Goldoni — Environment variables for Inquiry-Forms (Server Action src/app/actions/inquiry.ts).
#
# Copy this file to `.env.local` (gitignored) for local dev, or set the
# values in Vercel → Project Settings → Environment Variables → Production
# for the live site.
#
# In development (NODE_ENV !== "production") missing values fall back to
# a dry-run that logs the would-be email to the server console — useful
# for local form testing without a real mailbox.
#
# In production a missing value triggers an honest error message to the
# user ("bitte rufen Sie uns kurz an"). NEVER leave these unset on prod.

# DomainFactory SMTP host. Use the SSL endpoint for port 465.
SMTP_HOST=sslout.df.eu

# 465 = implicit SSL (recommended). 587 = STARTTLS (also supported by df.eu).
SMTP_PORT=465

# Full mailbox address — must be a real account at the configured provider.
SMTP_USER=info@ristorante-goldoni.de

# Mailbox password.
SMTP_PASS=

# RFC 5322 From-header. The user-part MUST be the SMTP_USER above (or a
# verified alias on the same mailbox), otherwise df.eu rejects with
# `550 sender not allowed`.
SMTP_FROM=Goldoni <info@ristorante-goldoni.de>

# Primary recipient — where the inquiries land (owner reads here daily).
INQUIRY_EMAIL_TO=info@ristorante-goldoni.de

# Optional CC — receives a copy of every inquiry. Leave empty to disable.
# Current use: operator copy to german@rauhut.com for oversight.
INQUIRY_EMAIL_CC=german@rauhut.com

# Token for the diagnostic SMTP-verify endpoint (src/app/api/smtp-verify).
# Long random string. Required to authorize calls to /api/smtp-verify;
# any mismatch returns 404 to avoid endpoint enumeration. Rotate after
# debugging is complete or remove the env-var to disable the endpoint.
SMTP_VERIFY_TOKEN=
