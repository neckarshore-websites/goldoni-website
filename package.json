{
  "name": "goldoni-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:quick": "node scripts/lighthouse.mjs --quick",
    "lighthouse:desktop": "node scripts/lighthouse.mjs --quick --profile=desktop",
    "lighthouse:mobile": "node scripts/lighthouse.mjs --quick --profile=mobile-4g",
    "lighthouse:slow": "node scripts/lighthouse.mjs --quick --profile=mobile-slow"
  },
  "dependencies": {
    "next": "16.2.3",
    "nodemailer": "8.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lighthouse": "13.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
