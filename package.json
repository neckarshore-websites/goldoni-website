{
  "name": "goldoni-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --grep-invert @external",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "lighthouse": "node scripts/lighthouse.mjs",
    "lighthouse:quick": "node scripts/lighthouse.mjs --quick",
    "lighthouse:desktop": "node scripts/lighthouse.mjs --quick --profile=desktop",
    "lighthouse:mobile": "node scripts/lighthouse.mjs --quick --profile=mobile-4g",
    "lighthouse:5g": "node scripts/lighthouse.mjs --quick --profile=mobile-5g",
    "test:lighthouse:unit": "node --test scripts/lighthouse-profiles.test.mjs",
    "typecheck": "tsc --noEmit",
    "test:search:unit": "NODE_ENV=production tsx tests/search/index-data.test.ts",
    "mail:preview": "tsx scripts/mail-preview.mjs"
  },
  "dependencies": {
    "minisearch": "7.2.0",
    "next": "16.2.6",
    "nodemailer": "9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lighthouse": "13.0.3",
    "tailwindcss": "^4",
    "tsx": "4.22.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.12",
    "js-yaml": "4.2.0",
    "@babel/core": "7.29.6"
  }
}
